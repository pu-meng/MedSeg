   "source": [
    "%%bash\n",
    "\n",
    "tmux new -s 名字\n",
    "\n",
    "U(Untracked)，新文件,从未被Git跟踪过的文件\n",
    "M(Modified)，已修改,被修改过但还没有被提交的文件\n",
    "D(Deleted)，已删除,被删除但还没有被提交的文件\n",
    "A(Added)，已添加,被添加到暂存区但还没有被提交的\n",
    "C(Conflict)，冲突,合并冲突的文件\n",
    "R(Renamed)，重命名,文件名被修改过\n",
    "T(Deleted by the user)，被用户删除\n",
    "!(Ignored)，被忽略,被Git忽略的文件"
   ]
  }
 ],
